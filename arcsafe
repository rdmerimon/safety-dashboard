<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ArcSafe ⚡ by RC</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0e0f11;--bg2:#141618;--bg3:#1c1e22;--bg4:#242628;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#f0f0ee;--text2:#9a9a96;--text3:#5e5e5a;
  --accent:#e85c2c;--accent2:#f07a50;--gold:#d4a843;--teal:#2ab89a;
  --blue:#4a8fe8;--red:#e24b4a;--purple:#a855f7;--green:#4caf50;
  --font:'DM Sans',sans-serif;--mono:'DM Mono',monospace;
  --radius:12px;--radius-sm:8px;
}
body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px;line-height:1.5;min-height:100vh;}

/* NAV */
.header{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:100;}
.header-left{display:flex;align-items:center;gap:12px;}
.logo-mark{width:32px;height:32px;border-radius:8px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:15px;color:#fff;}
.header-title{font-size:15px;font-weight:600;letter-spacing:-.02em;}
.header-sub{font-size:11px;color:var(--text2);}
.header-right{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.year-selector{display:flex;gap:4px;background:var(--bg3);border-radius:var(--radius-sm);padding:3px;border:1px solid var(--border);}
.year-tab{padding:4px 12px;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer;color:var(--text2);border:none;background:transparent;font-family:var(--font);transition:all .15s;}
.year-tab.active{background:var(--accent);color:#fff;}
.year-tab:hover:not(.active){color:var(--text);background:var(--bg4);}
.btn{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:var(--radius-sm);font-size:12px;font-weight:500;border:1px solid var(--border2);background:var(--bg3);color:var(--text2);cursor:pointer;font-family:var(--font);transition:all .15s;white-space:nowrap;}
.btn:hover{color:var(--text);background:var(--bg4);}
.btn-primary{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-primary:hover{opacity:.88;color:#fff;}

/* PAGE TABS */
.page-tabs{display:flex;gap:2px;background:var(--bg3);border-bottom:1px solid var(--border);padding:0 28px;overflow-x:auto;}
.page-tab{padding:11px 18px;font-size:12px;font-weight:500;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .15s;}
.page-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.page-tab:hover:not(.active){color:var(--text);}

/* PAGES */
.page{display:none;}.page.active{display:block;}
.main{padding:24px 28px;max-width:1400px;margin:0 auto;}
.section-label{font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;margin-top:8px;}

/* KPI GRIDS */
.kpi-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:24px;}
.kpi-grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:24px;}
.kpi-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:16px;transition:border-color .15s;}
.kpi-card:hover{border-color:var(--border2);}
.kpi-card.cb-accent{border-top:2px solid var(--accent);}
.kpi-card.cb-gold{border-top:2px solid var(--gold);}
.kpi-card.cb-teal{border-top:2px solid var(--teal);}
.kpi-card.cb-red{border-top:2px solid var(--red);}
.kpi-card.cb-blue{border-top:2px solid var(--blue);}
.kpi-card.cb-purple{border-top:2px solid var(--purple);}
.kpi-card.cb-green{border-top:2px solid var(--green);}
.kpi-label{font-size:11px;color:var(--text2);margin-bottom:6px;font-weight:500;}
.kpi-value{font-size:28px;font-weight:300;letter-spacing:-.04em;line-height:1;}
.kpi-sub{font-size:11px;color:var(--text3);margin-top:4px;}

/* CHART CARDS */
.chart-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;}
.chart-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;gap:8px;}
.chart-title{font-size:13px;font-weight:600;}
.chart-sub{font-size:11px;color:var(--text2);margin-top:2px;}
.badge{font-size:10px;padding:3px 8px;border-radius:4px;font-weight:600;white-space:nowrap;}
.badge-accent{background:rgba(232,92,44,.15);color:var(--accent2);}
.badge-red{background:rgba(226,75,74,.15);color:#f07a79;}
.badge-teal{background:rgba(42,184,154,.15);color:var(--teal);}
.badge-gold{background:rgba(212,168,67,.15);color:var(--gold);}
.badge-blue{background:rgba(74,143,232,.15);color:var(--blue);}
.badge-purple{background:rgba(168,85,247,.15);color:var(--purple);}

/* LAYOUT GRIDS */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:20px;}
.grid-21{display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:20px;}
.grid-12{display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:20px;}
.full{margin-bottom:20px;}

/* LEGEND */
.legend{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:12px;}
.legend-item{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text2);}
.legend-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0;}

/* PILLS */
.pill{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;}
.pill-red{background:rgba(226,75,74,.15);color:#f07a79;}
.pill-amber{background:rgba(212,168,67,.15);color:#d4a843;}
.pill-teal{background:rgba(42,184,154,.15);color:var(--teal);}
.pill-blue{background:rgba(74,143,232,.15);color:var(--blue);}
.pill-purple{background:rgba(168,85,247,.15);color:var(--purple);}
.pill-green{background:rgba(76,175,80,.15);color:var(--green);}
.pill-orange{background:rgba(232,92,44,.15);color:var(--accent2);}

/* PROGRESS */
.prog-wrap{width:100%;background:var(--bg3);border-radius:4px;height:4px;}
.prog-bar{height:4px;border-radius:4px;transition:width .4s;}

/* MONTH STRIP */
.month-strip{display:grid;grid-template-columns:repeat(12,1fr);gap:6px;margin-top:6px;}
.month-cell{border-radius:6px;display:flex;align-items:center;justify-content:center;flex-direction:column;cursor:pointer;border:1px solid var(--border);background:var(--bg3);padding:10px 4px;transition:all .15s;}
.month-cell:hover{border-color:var(--border2);background:var(--bg4);}
.month-name{font-size:9px;font-weight:600;color:var(--text3);text-transform:uppercase;}
.month-count{font-size:16px;font-weight:300;color:var(--text);line-height:1;margin-top:2px;}
.month-cell[data-level="0"]{opacity:.4;}
.month-cell[data-level="1"] .month-count{color:var(--teal);}
.month-cell[data-level="2"] .month-count{color:var(--gold);}
.month-cell[data-level="3"] .month-count{color:var(--accent);}

/* TABLES */
.table-scroll{overflow-x:auto;}
.data-table{width:100%;border-collapse:collapse;min-width:600px;}
.data-table th{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);padding:0 8px 10px 0;text-align:left;white-space:nowrap;}
.data-table td{padding:8px 8px 8px 0;border-top:1px solid var(--border);font-size:12px;vertical-align:middle;}
.data-table tr:hover td{background:rgba(255,255,255,.02);}

/* OSHA TABLE */
.osha-table{width:100%;border-collapse:collapse;font-size:12px;}
.osha-table th{background:var(--bg3);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--text2);padding:10px 12px;text-align:left;border:1px solid var(--border);white-space:nowrap;}
.osha-table td{padding:9px 12px;border:1px solid var(--border);color:var(--text);}
.osha-table tr:nth-child(even) td{background:var(--bg3);}
.osha-total td{color:var(--gold);font-weight:600;background:rgba(212,168,67,.08) !important;}
.osha-highlight{color:var(--accent) !important;font-weight:600;}

/* REC LIST */
.rec-list{display:flex;flex-direction:column;gap:8px;}
.rec-item{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;background:var(--bg3);border-radius:var(--radius-sm);border:1px solid var(--border);}
.rec-icon{width:28px;height:28px;min-width:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px;}
.rec-text{font-size:12px;color:var(--text2);line-height:1.4;}
.rec-text strong{color:var(--text);font-weight:500;display:block;margin-bottom:2px;}

/* INITIATIVE */
.init-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px;}
.init-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:16px;cursor:pointer;transition:all .15s;}
.init-card:hover{border-color:var(--border2);}
.init-card.selected{border-color:var(--accent);}
.init-icon{font-size:22px;margin-bottom:8px;}
.init-title{font-size:11px;font-weight:600;color:var(--text);line-height:1.3;margin-bottom:4px;}
.init-count{font-size:24px;font-weight:300;color:var(--accent);}
.init-label{font-size:10px;color:var(--text3);}

/* CLASS TABS */
.class-tabs{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.class-tab{padding:6px 14px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid var(--border2);color:var(--text2);background:var(--bg3);transition:all .15s;}
.class-tab.active-near{background:rgba(168,85,247,.2);border-color:var(--purple);color:var(--purple);}
.class-tab.active-first{background:rgba(42,184,154,.2);border-color:var(--teal);color:var(--teal);}
.class-tab.active-record{background:rgba(226,75,74,.2);border-color:var(--red);color:#f07a79;}
.class-tab.active-prop{background:rgba(212,168,67,.2);border-color:var(--gold);color:var(--gold);}
.class-tab.active-all{background:rgba(232,92,44,.2);border-color:var(--accent);color:var(--accent2);}

/* MODAL */
.modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.75);z-index:9000;overflow-y:auto;align-items:flex-start;justify-content:center;padding:40px 16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--radius);padding:28px;width:560px;max-width:100%;margin:auto;}
.modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
.modal-title{font-size:15px;font-weight:600;}
.close-btn{width:28px;height:28px;border-radius:6px;background:var(--bg3);border:1px solid var(--border);cursor:pointer;color:var(--text2);display:flex;align-items:center;justify-content:center;font-size:15px;}
.form-group{margin-bottom:14px;}
.form-label{font-size:11px;font-weight:600;color:var(--text2);margin-bottom:5px;display:block;text-transform:uppercase;letter-spacing:.06em;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.form-input,.form-select,.form-textarea{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:8px 12px;color:var(--text);font-family:var(--font);font-size:13px;outline:none;transition:border-color .15s;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--accent);}
.form-select option{background:var(--bg2);}
.form-textarea{resize:vertical;min-height:60px;}
.submit-btn{width:100%;padding:10px;background:var(--accent);border:none;border-radius:var(--radius-sm);color:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:var(--font);transition:opacity .15s;margin-top:4px;}
.submit-btn:hover{opacity:.88;}
.form-section-head{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);padding:10px 0 6px;border-top:1px solid var(--border);margin-top:8px;}

/* TOAST */
.toast{position:fixed;bottom:24px;right:24px;background:var(--bg3);border:1px solid var(--teal);border-radius:var(--radius-sm);padding:10px 16px;font-size:12px;color:var(--teal);z-index:9500;display:none;align-items:center;gap:8px;white-space:nowrap;}
.toast.show{display:flex;}

/* IMPORT MODAL */
.import-modal{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--radius);padding:24px;width:480px;max-width:100%;margin:auto;}
.import-step{display:flex;gap:12px;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(--border);}
.import-step:last-of-type{border-bottom:none;}
.import-num{width:26px;height:26px;min-width:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;background:var(--accent);color:#fff;flex-shrink:0;}
.import-step-text{font-size:12px;color:var(--text2);line-height:1.5;}
.import-step-text strong{color:var(--text);display:block;margin-bottom:2px;font-size:13px;}
.import-drop{border:2px dashed var(--border2);border-radius:var(--radius);padding:28px;text-align:center;margin:16px 0;cursor:pointer;transition:border-color .15s;}
.import-drop:hover,.import-drop.dragover{border-color:var(--accent);}
.import-drop i{font-size:32px;color:var(--text3);display:block;margin-bottom:8px;}
.import-drop-text{font-size:13px;color:var(--text2);}
.import-drop-sub{font-size:11px;color:var(--text3);margin-top:4px;}
.import-actions{display:flex;gap:10px;margin-top:4px;}
.import-merge-opt{display:flex;align-items:center;gap:8px;padding:10px 12px;background:var(--bg3);border-radius:var(--radius-sm);border:1px solid var(--border);cursor:pointer;}
.import-merge-opt input[type=radio]{accent-color:var(--accent);width:16px;height:16px;}
.import-merge-label{font-size:12px;color:var(--text);font-weight:500;}
.import-merge-sub{font-size:11px;color:var(--text2);}
.import-status{font-size:12px;min-height:18px;margin-top:8px;text-align:center;}

/* INIT LOG */
.init-log{display:flex;flex-direction:column;gap:6px;max-height:300px;overflow-y:auto;}
.init-log-item{display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:var(--bg3);border-radius:var(--radius-sm);border:1px solid var(--border);font-size:12px;gap:8px;}
.init-del{cursor:pointer;color:var(--text3);font-size:14px;padding:2px 4px;}
.init-del:hover{color:var(--red);}

/* SCROLLBAR */
::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:4px;}

/* ROLE & ACCESS */
#roleIndicator{display:none;align-items:center;gap:5px;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;}
#roleIndicator.admin{background:rgba(232,92,44,.15);color:#f07a50;display:flex;}
#roleIndicator.viewer{background:rgba(74,143,232,.15);color:#4a8fe8;display:flex;}
.write-control{transition:opacity .2s;}
body.view-only .write-control{opacity:.3;pointer-events:none;cursor:not-allowed;}

/* LOCK / SETUP SCREEN */
.auth-screen{position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:#0e0f11;display:flex;align-items:center;justify-content:center;padding:20px;overflow-y:auto;}
.auth-screen.hidden{display:none;}
.auth-card{width:400px;max-width:100%;background:#141618;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:36px 32px;display:flex;flex-direction:column;align-items:center;}
.auth-logo{width:56px;height:56px;border-radius:14px;background:#e85c2c;display:flex;align-items:center;justify-content:center;font-size:26px;color:#fff;margin-bottom:16px;}
.auth-title{font-size:20px;font-weight:600;color:#f0f0ee;letter-spacing:-.02em;margin-bottom:4px;text-align:center;}
.auth-sub{font-size:12px;color:#5e5e5a;margin-bottom:24px;text-align:center;line-height:1.6;}
.auth-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#5e5e5a;display:block;margin-bottom:5px;width:100%;text-align:left;}
.auth-input-wrap{width:100%;position:relative;margin-bottom:12px;}
.auth-input{width:100%;background:#1c1e22;border:1px solid rgba(255,255,255,0.13);border-radius:10px;padding:12px 44px 12px 16px;color:#f0f0ee;font-family:'DM Mono',monospace;font-size:14px;outline:none;letter-spacing:.04em;transition:border-color .15s;}
.auth-input:focus{border-color:#e85c2c;}
.auth-input.error{border-color:#e24b4a;animation:shake .35s ease;}
.auth-eye{position:absolute;right:13px;top:50%;transform:translateY(-50%);cursor:pointer;color:#5e5e5a;font-size:16px;background:none;border:none;padding:4px;}
.auth-eye:hover{color:#9a9a96;}
.auth-btn{width:100%;padding:13px;background:#e85c2c;border:none;border-radius:10px;color:#fff;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:opacity .15s;margin-top:4px;}
.auth-btn:hover{opacity:.88;}
.auth-btn.secondary{background:transparent;border:1px solid rgba(255,255,255,0.13);color:#9a9a96;margin-top:8px;}
.auth-btn.secondary:hover{color:#f0f0ee;border-color:rgba(255,255,255,0.25);}
.auth-error{font-size:12px;color:#e24b4a;margin-top:8px;min-height:16px;text-align:center;width:100%;}
.auth-success{font-size:12px;color:#2ab89a;margin-top:8px;min-height:16px;text-align:center;width:100%;}
.auth-divider{width:100%;border:none;border-top:1px solid rgba(255,255,255,0.07);margin:16px 0;}
.auth-strength{width:100%;height:3px;background:#1c1e22;border-radius:2px;margin-top:6px;margin-bottom:12px;overflow:hidden;}
.auth-strength-bar{height:100%;border-radius:2px;transition:width .3s,background .3s;}
.setup-step{display:flex;align-items:center;gap:8px;font-size:11px;color:#5e5e5a;margin-bottom:16px;}
.setup-step-dot{width:20px;height:20px;border-radius:50%;border:1px solid rgba(255,255,255,0.13);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;}
.setup-step-dot.active{background:#e85c2c;border-color:#e85c2c;color:#fff;}
.setup-step-dot.done{background:#2ab89a;border-color:#2ab89a;color:#fff;}

@keyframes shake{0%,100%{transform:translateX(0);}20%{transform:translateX(-7px);}40%{transform:translateX(7px);}60%{transform:translateX(-5px);}80%{transform:translateX(5px);}}
</style>
</head>
<body>

<header class="header">
  <div class="header-left">
    <div class="logo-mark"><i class="ti ti-bolt"></i></div>
    <div>
      <div class="header-title">ArcSafe ⚡ <span style="font-weight:300;">by RC</span></div>
      <div class="header-sub">Incident Tracking · OSHA Reporting · Safety Intelligence</div>
    </div>
  </div>
  <div class="header-right">
    <div id="roleIndicator"></div>
    <div id="syncStatus" title="Sync status" style="font-size:16px;cursor:pointer;" onclick="sbLoadAll()"></div>
    <div class="year-selector" id="yearSelector"></div>
    <button class="btn btn-primary write-control" onclick="openModal()"><i class="ti ti-plus" style="font-size:13px"></i> Log Incident</button>
    <button class="btn write-control" onclick="openImportModal()"><i class="ti ti-upload" style="font-size:13px"></i> Import</button>
    <button class="btn" onclick="exportAll()"><i class="ti ti-download" style="font-size:13px"></i> Export</button>
    <button class="btn write-control" onclick="openChangePw()" title="Change passwords"><i class="ti ti-lock" style="font-size:13px"></i> Passwords</button>
    <input type="file" id="importFileInput" accept=".json,.csv" style="display:none" onchange="handleImportFile(event)">
  </div>
</header>

<nav class="page-tabs">
  <div class="page-tab active" data-page="overview" onclick="switchPage('overview',this)"><i class="ti ti-layout-dashboard" style="font-size:13px;margin-right:5px"></i>Overview</div>
  <div class="page-tab" data-page="incidents" onclick="switchPage('incidents',this)"><i class="ti ti-alert-triangle" style="font-size:13px;margin-right:5px"></i>Incidents</div>
  <div class="page-tab" data-page="workforce" onclick="switchPage('workforce',this)"><i class="ti ti-users" style="font-size:13px;margin-right:5px"></i>Workforce</div>
