// ── LOGIN ─────────────────────────────────────────────────────────────────────
function doLogin() {
  var val = document.getElementById('loginPw').value;
  var err = document.getElementById('loginErr');
  var inp = document.getElementById('loginPw');
  var pw = loadPw();
  if (!pw) { err.textContent = 'No passwords found. Reload to run setup.'; return; }

  if (hashPw(val) === pw.a) {
    applyRole('admin');
    document.getElementById('loginScreen').classList.add('hidden');
    err.textContent = '';
  } else if (hashPw(val) === pw.v) {
    applyRole('viewer');
    document.getElementById('loginScreen').classList.add('hidden');
    err.textContent = '';
  } else if (val === MASTER_RESET_CODE) {
    // Recovery code entered on login screen — redirect to reset
    showResetScreen();
  } else {
    err.textContent = 'Incorrect password. Please try again.';
    inp.classList.add('error');
    inp.value = '';
    setTimeout(function(){ inp.classList.remove('error'); }, 400);
  }
}

// ── RESET ─────────────────────────────────────────────────────────────────────
function doReset() {
  var code = document.getElementById('resetCode').value;
  var err  = document.getElementById('resetErr');
  var ok   = document.getElementById('resetOk');
  if (code !== MASTER_RESET_CODE) {
    err.textContent = 'Incorrect recovery code.';
    document.getElementById('resetCode').classList.add('error');
    document.getElementById('resetCode').value = '';
    setTimeout(function(){ document.getElementById('resetCode').classList.remove('error'); }, 400);
    return;
  }
  // Wipe stored passwords — force setup wizard again
  try { localStorage.removeItem(PW_STORE); } catch(e) {}
  err.textContent = '';
  ok.textContent = '✓ Recovery code accepted. Reloading setup wizard…';
  setTimeout(function() {
    showScreen('setupScreen');
    // Reset setup wizard state
    document.getElementById('setupStep1').style.display = 'block';
    document.getElementById('setupStep2').style.display = 'none';
    document.getElementById('setupDot1').className = 'setup-step-dot active';
    document.getElementById('setupDot1').innerHTML = '1';
    document.getElementById('setupDot2').className = 'setup-step-dot';
    ['setup_admin1','setup_admin2','setup_view1','setup_view2'].forEach(function(id){ document.getElementById(id).value=''; });
    document.getElementById('setupErr1').textContent='';
    document.getElementById('setupErr2').textContent='';
  }, 1200);
}

// ── CHANGE PASSWORD (in-app) ──────────────────────────────────────────────────
function doChangePw() {
  var current = document.getElementById('cpw_current').value;
  var newAdmin = document.getElementById('cpw_admin').value;
  var newView  = document.getElementById('cpw_view').value;
  var err = document.getElementById('cpwErr');
  var ok  = document.getElementById('cpwOk');
  var pw  = loadPw();
  err.textContent = ''; ok.textContent = '';
  if (!pw || hashPw(current) !== pw.a) { err.textContent = 'Current admin password is incorrect.'; return; }
  if (newAdmin.length < 6)             { err.textContent = 'New admin password must be at least 6 characters.'; return; }
  if (newView.length < 6)              { err.textContent = 'View-only password must be at least 6 characters.'; return; }
  if (newAdmin === newView)            { err.textContent = 'Admin and view-only passwords must be different.'; return; }
  savePw(newAdmin, newView);
  ok.textContent = '✓ Passwords updated successfully.';
  setTimeout(function(){ closeChangePw(); }, 1500);
}

// ── APPLY ROLE ────────────────────────────────────────────────────────────────
function applyRole(role) {
  var ri = document.getElementById('roleIndicator');
  if (role === 'admin') {
    document.body.classList.remove('view-only');
    if (ri) { ri.className = 'admin'; ri.innerHTML = '<i class="ti ti-shield-filled" style="font-size:12px"></i> Admin'; }
  } else {
    document.body.classList.add('view-only');
    if (ri) { ri.className = 'viewer'; ri.innerHTML = '<i class="ti ti-eye" style="font-size:12px"></i> View only'; }
  }
}

// ── INIT AUTH ─────────────────────────────────────────────────────────────────
(function initAuth() {
  var pw = loadPw();
  if (!pw) {
    // First run — show setup wizard
    showScreen('setupScreen');
  } else {
    // Passwords exist — show login
    showScreen('loginScreen');
    setTimeout(function(){ var el=document.getElementById('loginPw'); if(el) el.focus(); }, 100);
  }
}());

document.addEventListener('DOMContentLoaded', function() {
  // Build password button + role indicator in header
  const headerRight = document.querySelector('.header-right');
  if(headerRight){
  }
  // Set today's date on all date fields
  const today=new Date().toISOString().split('T')[0];
  ['f_date','init_date','d_date'].forEach(id=>{const e=document.getElementById(id);if(e)e.value=today;});
  // Init dropdowns
  updateLevelOptions();
  updateDrillAreas();
  // Initial render from local data first (instant)
  buildYearTabs();
  try{ renderAll(); }catch(e){ console.warn('renderAll error:',e); }
  // Then sync from Supabase (updates if online)
  setSyncStatus('syncing');
  sbLoadAll();
});
</script>

