function handleImportDrop(evt){
  evt.preventDefault();
  document.getElementById('importDrop').classList.remove('dragover');
  const file=evt.dataTransfer.files[0];
  if(file)parseImportFile(file);
}

function parseImportFile(file){
  const status=document.getElementById('importStatus');
  const dropText=document.getElementById('importDrop').querySelector('.import-drop-text');
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const text=e.target.result;
      if(file.name.endsWith('.csv')){
        _pendingImportData=parseCSVImport(text);
        status.style.color='var(--teal)';
        status.textContent='✓ CSV parsed: '+_pendingImportData.incidentCount+' incidents found for import';
      } else {
        const parsed=JSON.parse(text);
        if(!parsed.incidents){throw new Error('Not a valid ArcSafe backup file');}
        _pendingImportData=parsed;
        const totalInc=Object.values(parsed.incidents||{}).reduce((a,b)=>a+b.length,0);
        const totalDrills=Object.values(parsed.drills||{}).reduce((a,b)=>a+b.length,0);
        const totalInit=Object.values(parsed.initiatives||{}).reduce((a,b)=>a+b.length,0);
        status.style.color='var(--teal)';
        status.textContent='✓ Backup from '+( parsed.exportDate?parsed.exportDate.split('T')[0]:'unknown date')+' — '+totalInc+' incidents, '+totalDrills+' drills, '+totalInit+' initiative entries';
      }
      dropText.textContent=file.name;
    }catch(err){
      _pendingImportData=null;
      status.style.color='var(--red)';
      status.textContent='✗ Error reading file: '+err.message;
      dropText.textContent='Tap to choose file';
    }
  };
  reader.readAsText(file);
}

function parseCSVImport(text){
  const lines=text.trim().split('\n');
  const headers=lines[0].split(',').map(h=>h.trim().toLowerCase());
  const rows=[];
  for(let i=1;i<lines.length;i++){
    if(!lines[i].trim())continue;
    const cols=lines[i].split(',');
    const r={};
    headers.forEach((h,idx)=>{r[h]=cols[idx]||'';});
    const date=r['date']||'';
    if(!date)continue;
    const mo=new Date(date+'T12:00:00').getMonth();
    rows.push({
      date,month:isNaN(mo)?0:mo,
      dow:r['day']||'',
      injury:r['injury']||'',
      classification:r['classification']||'Recordable',
      level:r['level']||'',
      group:r['group']||'field',
      time:r['time']||'morning',
      timeRaw:r['time']||'',
      ppe:r['ppe']||'',
      swa:r['swa']||'N/A',
      cause:r['cause']||'',
      notes:r['notes']||'',
      daysAway:parseInt(r['daysaway'])||0,
      daysRestricted:parseInt(r['daysrestricted'])||0,
    });
  }
  const byYear={};
  rows.forEach(r=>{
    const y=parseInt(r.date.split('-')[0]);
    if(!byYear[y])byYear[y]=[];
    byYear[y].push(r);
  });
  return{incidents:byYear,drills:{},initiatives:{},incidentCount:rows.length};
}

function triggerImport(){
  if(!_pendingImportData){
    document.getElementById('importStatus').style.color='var(--gold)';
    document.getElementById('importStatus').textContent='Please select a file first.';
    document.getElementById('importFileInput').click();
    return;
  }
  const mode=document.querySelector('input[name="importMode"]:checked').value;
  const status=document.getElementById('importStatus');
  try{
    if(mode==='replace'){
      // Full replace
      if(_pendingImportData.incidents)DATA=_pendingImportData.incidents;
      if(_pendingImportData.initiatives)INIT_DATA=_pendingImportData.initiatives;
      if(_pendingImportData.drills)DRILL_DATA=_pendingImportData.drills;
    } else {
      // Merge — add records that don't already exist (matched by date+injury+notes)
      const imp=_pendingImportData.incidents||{};
      Object.keys(imp).forEach(yr=>{
        const y=parseInt(yr);
        if(!DATA[y])DATA[y]=[];
        const existing=DATA[y];
        let added=0;
        (imp[yr]||[]).forEach(rec=>{
          const dup=existing.find(e=>e.date===rec.date&&e.injury===rec.injury&&(e.notes||'')===(rec.notes||''));
          if(!dup){existing.push(rec);added++;}
        });
      });
      // Merge initiatives
      const impInit=_pendingImportData.initiatives||{};
      Object.keys(impInit).forEach(yr=>{
        const y=parseInt(yr);
        if(!INIT_DATA[y])INIT_DATA[y]=[];
        (impInit[yr]||[]).forEach(rec=>{
          const dup=INIT_DATA[y].find(e=>e.date===rec.date&&e.cat===rec.cat&&(e.desc||'')===(rec.desc||''));
          if(!dup)INIT_DATA[y].push(rec);
        });
      });
      // Merge drills
      const impDrills=_pendingImportData.drills||{};
      Object.keys(impDrills).forEach(yr=>{
        const y=parseInt(yr);
        if(!DRILL_DATA[y])DRILL_DATA[y]=[];
        (impDrills[yr]||[]).forEach(rec=>{
          const dup=DRILL_DATA[y].find(e=>e.date===rec.date&&e.type===rec.type&&e.area===rec.area);
          if(!dup)DRILL_DATA[y].push(rec);
        });
      });
    }
    // Rebuild year list and save
    saveData();saveInitData();saveDrills();
    allYears=[...new Set([...Object.keys(DATA).map(Number),...Object.keys(INIT_DATA).map(Number),...Object.keys(DRILL_DATA).map(Number)])].filter(y=>y>2000).sort();
    buildYearTabs();
    renderAll();
    status.style.color='var(--teal)';
    status.textContent='✓ Import complete! Data updated across all tabs.';
    setTimeout(()=>closeImportModal(),1800);
    showToast('Import successful');
  }catch(err){
    status.style.color='var(--red)';
    status.textContent='✗ Import failed: '+err.message;
  }
}

