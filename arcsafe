function workerGroup(r){
  if(r.group)return r.group;
  const l=(r.level||'').toLowerCase();
  if(l.includes('admin')||l.includes('pm')||l.includes('pe')||l.includes('px')||l.includes('hr')||l.includes('accounting'))return'office';
  if(l.includes('stockman')||l.includes('driver')||l.includes('production'))return'warehouse';
  return'field';
}
function isApprentice(r){return(r.level||'').toLowerCase().includes('apprentice');}
function isJW(r){return(r.level||'').toLowerCase().includes('journeyman');}
function isForeman(r){return(r.level||'').toLowerCase().includes('foreman');}

