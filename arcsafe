const MASTER_RESET_CODE = 'ArcSafe-RC-2025-RESET';
const PW_STORE = 'arcsafe_pw_v1';

// Simple hash — XOR-based obfuscation so passwords aren't plain text in storage
function hashPw(str) {
  var h = 0;
  for (var i = 0; i < str.length; i++) {
    h = (Math.imul(31, h) + str.charCodeAt(i)) | 0;
  }
  return h.toString(36);
}

function loadPw() {
  try {
    var r = localStorage.getItem(PW_STORE);
    return r ? JSON.parse(r) : null;
  } catch(e) { return null; }
}
function savePw(adminPw, viewPw) {
  try {
    localStorage.setItem(PW_STORE, JSON.stringify({
      a: hashPw(adminPw),
      v: hashPw(viewPw),
      ts: Date.now()
    }));
    return true;
  } catch(e) { return false; }
}

