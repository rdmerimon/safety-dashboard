    a.href='data:application/json;charset=utf-8,'+encodeURIComponent(json);
    a.download=filename;document.body.appendChild(a);a.click();
    setTimeout(()=>document.body.removeChild(a),500);
  }
  showToast('Backup saved: '+filename);
}

