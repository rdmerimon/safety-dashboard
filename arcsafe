// ── SUPABASE SYNC ─────────────────────────────────────────────────────────────
var SB_URL = 'https://bcjalazareaspzivplbz.supabase.co';
var SB_KEY = 'sb_publishable_cNfzkM0UZtJudntkNzqh7w_kdpyqtIA';
var SB_ONLINE = false; // set true once first sync succeeds

function sbHeaders(extra) {
  var h = {
    'apikey': SB_KEY,
    'Authorization': 'Bearer ' + SB_KEY,
    'Content-Type': 'application/json',
    'Prefer': 'return=representation'
  };
  if (extra) Object.assign(h, extra);
  return h;
}

// Generic fetch wrapper — falls back silently to localStorage if offline
function sbFetch(path, options) {
  return fetch(SB_URL + '/rest/v1/' + path, Object.assign({headers: sbHeaders()}, options || {}))
    .then(function(r) {
      if (!r.ok) return r.text().then(function(t){ throw new Error('SB ' + r.status + ': ' + t); });
      return r.json();
    });
}

// ── SYNC STATUS INDICATOR ─────────────────────────────────────────────────────
function setSyncStatus(state) {
  var el = document.getElementById('syncStatus');
  if (!el) return;
  if (state === 'ok')      { el.innerHTML = '<i class="ti ti-cloud-check" style="color:var(--teal)"></i>'; el.title = 'Synced to cloud'; }
  else if (state === 'syncing') { el.innerHTML = '<i class="ti ti-loader-2 ti-spin" style="color:var(--gold)"></i>'; el.title = 'Syncing…'; }
  else if (state === 'offline') { el.innerHTML = '<i class="ti ti-cloud-off" style="color:var(--text3)"></i>'; el.title = 'Offline — using local data'; }
  else if (state === 'error')   { el.innerHTML = '<i class="ti ti-cloud-x" style="color:var(--red)"></i>'; el.title = 'Sync error — check connection'; }
}

// ── LOAD ALL DATA FROM SUPABASE ───────────────────────────────────────────────
function sbLoadAll() {
  setSyncStatus('syncing');
  var promises = [
    sbFetch('incidents?order=date.asc&limit=5000'),
    sbFetch('initiatives?order=date.asc&limit=5000'),
    sbFetch('drills?order=date.asc&limit=5000')
  ];
  return Promise.all(promises).then(function(results) {
    var incidents  = results[0];
    var initiatives = results[1];
    var drills     = results[2];

    // Rebuild DATA object keyed by year
    var newData = {};
    incidents.forEach(function(r) {
      var y = parseInt((r.date||'').split('-')[0]);
      if (!y || isNaN(y)) return;
      if (!newData[y]) newData[y] = [];
      // Map DB columns back to dashboard format
      newData[y].push({
        date: r.date, month: r.month||0, dow: r.dow||'',
        injury: r.injury||'', classification: r.classification||'Recordable',
        level: r.level||'', group: r.worker_group||'field',
        time: r.time_window||'morning', timeRaw: r.time_raw||'',
        ppe: r.ppe||'', cause: r.cause||'', swa: r.swa||'N/A',
        notes: r.notes||'', daysAway: r.days_away||0,
        daysRestricted: r.days_restricted||0, id: r.id
      });
    });

    var newInit = {};
    initiatives.forEach(function(r) {
      var y = parseInt((r.date||'').split('-')[0]);
      if (!y || isNaN(y)) return;
      if (!newInit[y]) newInit[y] = [];
      newInit[y].push({ cat: r.category||'', date: r.date||'', desc: r.description||'', id: r.id });
    });

    var newDrills = {};
    drills.forEach(function(r) {
      var y = parseInt((r.date||'').split('-')[0]);
      if (!y || isNaN(y)) return;
      if (!newDrills[y]) newDrills[y] = [];
      newDrills[y].push({
        date: r.date, month: r.month||0, type: r.drill_type||'',
        facility: r.facility||'', area: r.area||'',
        start: r.start_time||'', end: r.end_time||'',
        duration: r.duration_mins||null, result: r.result||'',
        conductor: r.conductor||'', notes: r.notes||'', id: r.id
      });
    });

    DATA      = Object.keys(newData).length  ? newData  : DATA;
    INIT_DATA = Object.keys(newInit).length  ? newInit  : INIT_DATA;
    DRILL_DATA= Object.keys(newDrills).length? newDrills: DRILL_DATA;

    // Also cache locally as backup
    _ls.set(STORAGE_KEY,   JSON.stringify(DATA));
    _ls.set(STORAGE_INIT,  JSON.stringify(INIT_DATA));
    _ls.set(STORAGE_DRILLS,JSON.stringify(DRILL_DATA));

    SB_ONLINE = true;
    setSyncStatus('ok');
    allYears = [...new Set([
      ...Object.keys(DATA).map(Number),
      ...Object.keys(INIT_DATA).map(Number),
      ...Object.keys(DRILL_DATA).map(Number)
    ])].filter(function(y){ return y > 2000; }).sort();
    buildYearTabs();
    renderAll();
    console.log('ArcSafe: synced from Supabase —', incidents.length, 'incidents,', drills.length, 'drills,', initiatives.length, 'initiatives');
  }).catch(function(err) {
    console.warn('ArcSafe: Supabase unavailable, using local data.', err.message);
    SB_ONLINE = false;
    setSyncStatus('offline');
  });
}

// ── SAVE INCIDENT TO SUPABASE ─────────────────────────────────────────────────
function sbSaveIncident(rec) {
  if (!SB_ONLINE) return Promise.resolve(null);
  var row = {
    date: rec.date, month: rec.month, dow: rec.dow,
    injury: rec.injury, classification: rec.classification,
    level: rec.level, worker_group: rec.group,
    time_window: rec.time, time_raw: rec.timeRaw||'',
    ppe: rec.ppe, cause: rec.cause, swa: rec.swa||'N/A',
    notes: rec.notes||'', days_away: rec.daysAway||0,
    days_restricted: rec.daysRestricted||0
  };
  return sbFetch('incidents', {
    method: 'POST',
    headers: sbHeaders({'Prefer':'return=representation'}),
    body: JSON.stringify(row)
  }).then(function(r) {
    if (r && r[0]) rec.id = r[0].id;
    setSyncStatus('ok');
    return r;
  }).catch(function(e){ setSyncStatus('error'); console.error('sbSaveIncident:', e); });
}

